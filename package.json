{
  "name": "kingdomcars",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade Next.js 16 + Payload 3 site for KingdomCars (PL/EN/RU).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots=all",
    "payload": "payload",
    "payload:gen:types": "payload generate:types",
    "payload:migrate": "tsx --import ./scripts/bootstrap-env.mts scripts/migrate.ts",
    "seed": "tsx --import ./scripts/bootstrap-env.mts scripts/seed.ts",
    "analyze": "ANALYZE=true next build",
    "bundlewatch": "bundlewatch --config bundlewatch.config.json",
    "gen:component": "tsx scripts/generate-component.ts",
    "postinstall": "node scripts/patch-payload.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@parcel/watcher": "^2.5.6",
    "@payloadcms/db-postgres": "^3.40.0",
    "@payloadcms/next": "^3.40.0",
    "@payloadcms/richtext-lexical": "^3.40.0",
    "@payloadcms/ui": "^3.40.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@sentry/nextjs": "^10.0.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "graphql": "^16.10.0",
    "lucide-react": "^0.475.0",
    "next": "^16.2.6",
    "next-intl": "^4.11.1",
    "otplib": "^12.0.1",
    "payload": "^3.40.0",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.54.2",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/postcss": "^4.0.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.4",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.5",
    "bundlewatch": "^0.4.0",
    "eslint": "^9.20.1",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^57.0.0",
    "jsdom": "^26.0.0",
    "lefthook": "^1.10.10",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.1",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
