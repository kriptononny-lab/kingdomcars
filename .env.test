# Test-only env. Loaded by Vitest via `vi.stubEnv` + by Playwright webServer.env.
# Real values for non-secret fields stay in .env.local; tests only override
# what they need to override.

NODE_ENV=test
LOG_LEVEL=warn

# Telegram mock — Playwright spins up a server on this URL.
TELEGRAM_API_BASE=http://localhost:9999

# Dummy required values (never leave the test sandbox).
TELEGRAM_BOT_TOKEN=test-bot-token
TELEGRAM_CHAT_ID=-100test
