{
  "version": "0.2.0",
  "configurations": [
    {
      // Run `next dev` under the Node debugger. Stops on uncaught exceptions
      // and `debugger` statements anywhere in server code (Server Components,
      // route handlers, server actions).
      "name": "Next.js: dev (server)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal",
      "env": {
        "NODE_OPTIONS": "--inspect"
      }
    },
    {
      // Attach to an already-running Next dev server (port 9229). Useful when
      // you started the app via Docker but want to debug into the container.
      "name": "Next.js: attach server",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      // Open a Chrome window pointed at localhost:3000 with the VS Code
      // debugger attached. Breakpoints in Client Components and browser code
      // resolve via sourcemaps.
      "name": "Next.js: dev (client Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${webRoot}/*"
      }
    },
    {
      // Run only the currently open test file in the debugger.
      "name": "Vitest: current file",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "name": "Vitest: all",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      // Open Playwright's interactive UI runner — the easiest way to step
      // through an e2e test.
      "name": "Playwright: debug (UI)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": ["test", "--ui"],
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      // Start dev server + open Chrome with debugger. One click, full-stack
      // debugging in two panes.
      "name": "Full debug (server + client)",
      "configurations": ["Next.js: dev (server)", "Next.js: dev (client Chrome)"],
      "stopAll": true
    }
  ]
}
