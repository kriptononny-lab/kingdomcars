# =============================================================================
# KingdomCars — env profile for docker compose.
# Copy to `.env` (NOT `.env.local` — compose reads `.env` next to compose file).
# All values are validated by src/lib/env.ts at app boot.
# =============================================================================

# ---- Domain & TLS -----------------------------------------------------------
# Caddy uses this to obtain a Let's Encrypt cert. While in localhost mode
# (see docker/caddy/Caddyfile) this is only echoed, not used.
SITE_DOMAIN=kingdomcars.example.com
ACME_EMAIL=admin@example.com

# ---- Public site URLs (must be HTTPS in prod) -------------------------------
NEXT_PUBLIC_SITE_URL=https://kingdomcars.example.com
NEXT_PUBLIC_SITE_HOST=kingdomcars.example.com
PAYLOAD_PUBLIC_SERVER_URL=https://kingdomcars.example.com

# ---- Postgres (compose-internal — `postgres` is the service hostname) -------
POSTGRES_DB=kingdomcars
POSTGRES_USER=payload
POSTGRES_PASSWORD=change_me_to_a_long_random_password

# ---- Payload secrets --------------------------------------------------------
PAYLOAD_SECRET=replace_me_with_a_32_char_random_string_here
REVALIDATE_SECRET=replace_me_with_16_chars_min

# ---- Telegram bot -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=000000000:replace_with_bot_token
TELEGRAM_CHAT_ID=-100replace_chat_id

# ---- Logging ----------------------------------------------------------------
LOG_LEVEL=info

# ---- Optional: Upstash Redis (rate-limit; falls back to in-memory) ---------
# UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
# UPSTASH_REDIS_REST_TOKEN=replace_me

# ---- Optional: Sentry -------------------------------------------------------
# SENTRY_DSN=https://public@sentry.io/projectId
# NEXT_PUBLIC_SENTRY_DSN=https://public@sentry.io/projectId
# NEXT_PUBLIC_SENTRY_RELEASE=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ---- Optional: Umami analytics (only when using docker-compose.umami.yml) --
# UMAMI_APP_SECRET=replace_me_with_a_long_random_string
# ANALYTICS_DOMAIN=analytics.kingdomcars.example.com
# NEXT_PUBLIC_ANALYTICS_URL=https://analytics.kingdomcars.example.com/script.js
# NEXT_PUBLIC_ANALYTICS_ID=replace_with_website_id

# ---- Optional: seed admin user (only when running `make seed`) -------------
# SEED_ADMIN_EMAIL=admin@kingdomcars.example.com
# SEED_ADMIN_PASSWORD=ChangeMe!Now123
