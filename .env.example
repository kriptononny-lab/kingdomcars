# =============================================================================
# KingdomCars — environment variables
# Copy to .env.local for local dev. Never commit .env or .env.local.
# All variables are validated through src/lib/env.ts (Zod). Invalid env =
# hard crash on boot.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# ---- Public site ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_HOST=localhost

# ---- Database (PostgreSQL 16+) ----------------------------------------------
DATABASE_URL=postgres://payload:payload@localhost:5432/kingdomcars

# ---- Payload CMS ------------------------------------------------------------
PAYLOAD_SECRET=replace_me_with_a_32_char_random_string_here
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# ---- Revalidation webhook ---------------------------------------------------
REVALIDATE_SECRET=replace_me_with_16_chars_min

# ---- Telegram bot (contact form sink) ---------------------------------------
TELEGRAM_BOT_TOKEN=000000000:replace_with_bot_token
TELEGRAM_CHAT_ID=-100replace_chat_id
# Optional — override the Telegram API endpoint. E2E tests set this to a local
# mock; production leaves it unset (falls back to TELEGRAM.API_BASE constant).
# TELEGRAM_API_BASE=http://localhost:9999

# ---- Upstash Redis (rate-limit; optional, falls back to in-memory) ----------
# UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
# UPSTASH_REDIS_REST_TOKEN=replace_me

# ---- Sentry (optional — SDK no-ops cleanly when DSN unset) ------------------
# SENTRY_DSN=https://public@sentry.io/projectId
# NEXT_PUBLIC_SENTRY_DSN=https://public@sentry.io/projectId
# NEXT_PUBLIC_SENTRY_RELEASE=local-dev
# SENTRY_ORG=your-org
# SENTRY_PROJECT=kingdomcars
# SENTRY_AUTH_TOKEN=replace_me

# ---- Analytics (Umami/Plausible, GDPR-friendly; optional) -------------------
# NEXT_PUBLIC_ANALYTICS_URL=https://analytics.example.com
# NEXT_PUBLIC_ANALYTICS_ID=replace_me

# ---- Seed (used by `npm run seed`; do NOT commit real values) ---------------
# SEED_ADMIN_EMAIL=admin@kingdomcars.example.com
# SEED_ADMIN_PASSWORD=ChangeMe!Now123
